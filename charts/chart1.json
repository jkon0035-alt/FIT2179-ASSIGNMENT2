{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "How Australia's Smoking Status Has Changed Over Time",
    "subtitle": "Proportion of Australians aged 14+, (2001–2023)",
    "fontSize": 15,
    "subtitleFontSize": 12,
    "anchor": "start"
    "color": "#333333",
    "subtitleColor": "#666666"
  },
  "width": "container",
  "height": 400,
  "data": {"url":"data/smoking-trend.csv"},
  "mark": {"type": "area", "opacity": 0.8},
  "encoding": {
    "x": {
      "field": "year",
      "type": "ordinal",
      "title": "Year",
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "percent",
      "type": "quantitative",
      "stack": "normalize",
      "title": "Proportion (%)",
      "axis": {"format": ".0%"}
    },
    "color": {
      "field": "category",
      "type": "nominal",
      "title": "Smoking status",
      "scale": {
        "domain": ["Never Smoked", "Smoked previously", "Currently Smoke", "Smoke Daily"],
        "range": ["#1D9E75","#B4B2A9","#E8956D","#993C1D"]
      }
    },
    "order": {
      "field": "category",
      "sort": ["Smoke Daily","Currently Smoke","Smoked Previously","Never Smoked"]
    },
    "legend": {
      "orient": "right", "titleFontSize": 12, "labelFontSize": 11
    },
    "tooltip": [
      {"field": "year", "type": "ordinal", "title": "Year"},
      {"field": "category", "type": "nominal", "title": "Status"},
      {"field": "percent", "type": "quantitative", "title": "%", "format": ".1f"}
    ]
  }
}
